<div class="page-header">
  <a href="/" class="btn-secondary">← Volver</a>
  <h2>Canciones</h2>
  <a href="/canciones/nueva" class="btn-primary">+ Nueva canción</a>
</div>

<ul>
  {{#each canciones}}
  <li>
    <a href="/canciones/{{this.id}}">{{this.titulo}}</a>
    <span class="meta">
      <span class="badge">{{this.Artistum.nombre}}</span>
      <span class="badge">{{this.album}}</span>
      <span class="badge">{{this.duracion}}s</span>
    </span>
    <form action="/canciones/{{this.id}}/eliminar" method="POST" style="display:inline;">
      <button type="submit" class="btn-danger" onclick="return confirm('¿Eliminar {{this.titulo}}?')">🗑</button>
    </form>
  </li>
  {{/each}}
</ul>