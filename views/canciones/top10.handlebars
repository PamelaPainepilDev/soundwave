<div class="page-header">
  <a href="/" class="btn-secondary">← Volver</a>
  <h2>🏆 Top 10 canciones</h2>
</div>

<ol>
  {{#each canciones}}
  <li>
    <a href="/canciones/{{this.id}}">{{this.titulo}}</a>
    <span class="meta">
      <span class="badge">{{this.Artistum.nombre}}</span>
      <span class="badge badge-green">{{this.reproducciones}} plays</span>
    </span>
  </li>
  {{/each}}
</ol>